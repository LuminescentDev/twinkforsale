# TwinkForSale Docker Environment Configuration
# Copy this file to .env in the docker/ directory

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
POSTGRES_USER=twinkforsale
POSTGRES_PASSWORD=twinkforsale_dev_change_in_prod
POSTGRES_DB=twinkforsale
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ==========================================
# BACKEND CONFIGURATION
# ==========================================

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=twinkforsale_dev_secret_key_please_change_to_something_secure_minimum_32_chars

# JWT Configuration
JWT_ISSUER=twinkforsale
JWT_AUDIENCE=twinkforsale_users

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:5000/auth/callback

# Storage Configuration
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=104857600  # 100MB in bytes

# S3/R2 Storage (optional - leave empty to use local filesystem)
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_BUCKET_NAME=
S3_BASE_URL=

# Base URL for the application
BASE_URL=http://localhost:3000

# ==========================================
# LOGGING CONFIGURATION
# ==========================================

# Loki URL for centralized logging
# Leave empty or comment out to disable Loki logging
LOKI_URL=http://loki:3100

# ==========================================
# MONITORING CONFIGURATION
# ==========================================

# Grafana Admin Credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_PASSWORD=admin

# Grafana Anonymous Access
GRAFANA_ANONYMOUS=false
GRAFANA_ANONYMOUS_ROLE=Viewer

# ==========================================
# NOTES
# ==========================================
# 
# To run the full stack:
#   docker-compose --profile full up -d
#
# To run with monitoring (Loki + Grafana):
#   docker-compose --profile full --profile monitoring up -d
#
# Or use the dedicated monitoring stack:
#   docker-compose -f docker-compose.monitoring.yml up -d
#
# Grafana will be available at: http://localhost:3200
# Default credentials: admin / admin (change GRAFANA_PASSWORD)
