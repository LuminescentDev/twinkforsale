# twink.forsale Frontend Environment Configuration
# Copy this file to .env and fill in your actual values
# 
# ==========================================
# REQUIRED VARIABLES
# ==========================================

# Internal Backend URL (for server-side API proxy routes)
# This is used by the frontend server to communicate with the backend
# Development: http://localhost:5000
# Docker: http://backend:5000
# Production: http://your-internal-backend-url:5000
BACKEND_URL="http://localhost:5000"

# ==========================================
# OPTIONAL VARIABLES
# ==========================================

# Public URL for ShareX configs (optional)
# If not set, will use the request origin
# PUBLIC_URL="https://twink.forsale"

# Node environment
# NODE_ENV="development"

# Port for frontend server (optional, defaults to 3000)
# PORT=3000

# Discord Webhook for system notifications (optional)
# DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
