# twink.forsale Frontend Environment Configuration
# Copy this file to .env and fill in your actual values
# 
# ==========================================
# REQUIRED VARIABLES
# ==========================================

# Internal Backend URL (for server-side API proxy routes)
# This is used by the frontend server to communicate with the backend
# Development: http://localhost:5000
# Docker: http://backend:5000
# Production: http://your-internal-backend-url:5000
BACKEND_URL="http://localhost:5000"

# Internal Frontend URL (for SSR self-requests)
# This is used when the frontend SSR needs to fetch from its own API routes
# Development: http://localhost:3000
# Docker: http://frontend:3000
# Production: http://your-internal-frontend-url:3000
FRONTEND_URL="http://localhost:3000"

# ==========================================
# OPTIONAL VARIABLES
# ==========================================

# Grafana Loki URL for centralized logging (optional)
# If not set or set to "disabled", only console logging will be used
# Development: http://localhost:3100
# Docker: http://loki:3100
# Production: https://your-loki-instance:3100
# LOKI_URL="http://localhost:3100"

# Public URL for ShareX configs (optional)
# If not set, will use the request origin
# PUBLIC_URL="https://twink.forsale"

# Node environment
# NODE_ENV="development"

# Port for frontend server (optional, defaults to 3000)
# PORT=3000

# Discord Webhook for system notifications (optional)
# DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
