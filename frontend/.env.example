# twink.forsale frontend environment configuration
# Copy this file to .env and fill in your actual values.
#
# The frontend is a Qwik app that talks to the C# backend for all data, auth,
# uploads and redirects. Database, Discord OAuth, storage and analytics config
# live in the backend (see backend/ and MIGRATION_PLAN.md), NOT here.

# Backend API base URL used by the frontend API client.
# Leave empty ("") in production where /api, /f and /l are proxied to the
# backend on the same origin. In local dev, point at the running C# backend.
VITE_API_BASE_URL="http://localhost:5000"

# Node server settings
NODE_ENV="production"
PORT=3004

# Base URL used as the Qwik City origin for the node server.
BASE_URL="https://twink.forsale"
